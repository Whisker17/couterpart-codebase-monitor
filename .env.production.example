# Copy this file to .env and fill in real values.
# Never commit .env or paste secrets into issues/chats.

# GitHub token for collector.
# Recommended fine-grained PAT permissions:
# - Metadata: Read-only
# - Pull requests: Read-only
GITHUB_TOKEN=

# Anthropic-compatible AI gateway used by analyzer.
LLM_BASE_URL=
LLM_API_KEY=

# Lark webhook URL for report delivery and health alerts.
LARK_WEBHOOK_URL=

# Runtime environment.
NODE_ENV=production

# Optional: override cron schedules from config/settings.json.
# SCHEDULE_DAILY_CRON="0 9 * * *"
# SCHEDULE_WEEKLY_CRON="0 10 * * 1"

# Optional: override monthly LLM cost cap (USD).
# BUDGET_MONTHLY_CAP=80
