# Copy this file to .env and fill in real values.
# Never commit .env or paste secrets into issues/chats.

# GitHub token for collector.
# Recommended fine-grained PAT permissions:
# - Metadata: Read-only
# - Pull requests: Read-only
GITHUB_TOKEN=

# Anthropic-compatible AI gateway used by analyzer.
LLM_BASE_URL=
LLM_API_KEY=

# Optional until Lark dispatcher is enabled.
LARK_WEBHOOK_URL=

# Tracked projects are maintained in config/projects.json (a JSON array of
# objects with a required "url" field and optional "tags" / "notes"). The
# file is re-read on every pipeline run — edits take effect without a restart.
