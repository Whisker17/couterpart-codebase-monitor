# Copy this file to .env and fill in real values.
# Never commit .env or paste secrets into issues/chats.

# GitHub token for collector.
# Recommended fine-grained PAT permissions:
# - Metadata: Read-only
# - Pull requests: Read-only
GITHUB_TOKEN=

# Anthropic-compatible AI gateway used by analyzer.
LLM_BASE_URL=
LLM_API_KEY=

# Optional until Lark dispatcher is enabled.
LARK_WEBHOOK_URL=

# Optional. When set, the project list is fetched from this URL instead of
# the local config/projects.json. Must return a JSON array of objects with
# a required "url" field (GitHub repo URL) and optional "tags" / "notes".
# Example: https://raw.githubusercontent.com/<owner>/<repo>/main/subscriptions.json
PROJECTS_SUBSCRIPTION_URL=
