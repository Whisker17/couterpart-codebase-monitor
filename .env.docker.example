# GitHub
GITHUB_TOKEN=ghp_xxx

# LLM (AI gateway)
LLM_BASE_URL=https://your-gateway.example.com/v1
LLM_API_KEY=sk-xxx

# Lark
LARK_WEBHOOK_URL=https://open.larksuite.com/open-apis/bot/v2/hook/xxx

# Timezone (default: Asia/Shanghai set in docker-compose.yml)
# TZ=Asia/Shanghai

# Optional: override schedule (times are interpreted in TZ above)
# DAILY_CRON=0 8 * * *
# WEEKLY_CRON=0 9 * * 1
